{
  "name": "screenshot-api",
  "version": "1.0.0",
  "description": "AI-ready web scraper API — URL to clean Markdown (Fastify + Playwright)",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "mcp-server": "node mcp-server.js",
    "dev": "node --watch index.js",
    "build": "prisma generate && npx playwright install --with-deps chromium",
    "prisma:generate": "prisma generate"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "fastify",
    "scraper",
    "cheerio",
    "markdown",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/session": "^11.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.0",
    "axios": "^1.13.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "franc-min": "^6.2.0",
    "jose": "^6.1.3",
    "pg": "^8.20.0",
    "playwright": "1.42.0",
    "prisma": "^6.19.0",
    "turndown": "^7.2.3",
    "zod": "^4.3.6"
  }
}
