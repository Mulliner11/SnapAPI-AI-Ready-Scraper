    "@fastify/session": "^11.1.1",
    "@prisma/client": "^6.19.0",
    "axios": "^1.13.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "jose": "^6.1.3",
    "pg": "^8.20.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "prisma": "^6.19.0"
  }
